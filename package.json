{
  "name": "helix",
  "version": "2.0.0",
  "private": true,
  "description": "Helix skills for AI coding assistants — exchange access, CEX execution, and Freqtrade strategy automation",
  "keywords": [
    "claude-code",
    "skills",
    "crypto",
    "trading",
    "freqtrade",
    "price-action",
    "strategy",
    "account",
    "execution",
    "helix",
    "openclaw"
  ],
  "author": {
    "name": "Helix"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/hway-git/helix.git"
  },
  "homepage": "https://github.com/hway-git/helix",
  "files": [
    "skills/",
    "AGENTS.md",
    "CLAUDE.md",
    ".claude-plugin/"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @helix/daemon --filter @helix/dashboard dev",
    "dev:daemon": "pnpm --filter @helix/daemon dev",
    "dev:dashboard": "pnpm --filter @helix/dashboard dev",
    "typecheck": "pnpm --filter @helix/contracts typecheck && pnpm --filter @helix/core typecheck && pnpm --filter @helix/daemon typecheck && pnpm --filter @helix/dashboard typecheck",
    "validate": "node scripts/validate-skills.mjs",
    "freqtrade:install": "node docker/freqtrade/install.mjs",
    "test:freqtrade": "node --test --test-concurrency=1 skills/helix-freqtrade/tests/*.test.mjs",
    "strategy:history": "pnpm --filter @helix/core strategy:history",
    "strategy:backtest": "pnpm --filter @helix/core strategy:backtest",
    "strategy:walk-forward": "pnpm --filter @helix/core strategy:walk-forward",
    "verify-orders": "node skills/helix-trading/scripts/verify-order-matrix.mjs",
    "prepublishOnly": "node scripts/validate-skills.mjs",
    "postinstall": "echo '\\n  helix skills installed!\\n  Skills: helix-account, helix-trading, helix-freqtrade\\n  Docs: README.md\\n'"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  }
}
